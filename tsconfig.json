{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "#features": ["./src/features/index"],
      "#features/*": ["./src/features/*"],
      "#design": ["./src/shared/design/index"],
      "#design/*": ["./src/shared/design/*"],
      "#shared/*": ["./src/shared/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
